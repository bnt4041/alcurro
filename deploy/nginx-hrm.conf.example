# Ejemplo Nginx — copiar a /etc/nginx/sites-available/hrm y enlazar en sites-enabled.
# Sustituir hrm.tudominio.com y rutas de certificado SSL.

upstream hrm_backend {
    server 127.0.0.1:8000;
    keepalive 32;
}

server {
    listen 80;
    server_name hrm.tudominio.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name hrm.tudominio.com;

    ssl_certificate     /etc/letsencrypt/live/hrm.tudominio.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/hrm.tudominio.com/privkey.pem;

    client_max_body_size 25M;

    root /var/www/hrm/frontend/dist;
    index index.html;

    location /api/ {
        proxy_pass http://hrm_backend/api/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /uploads/ {
        proxy_pass http://hrm_backend/uploads/;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /webhook/ {
        proxy_pass http://hrm_backend/webhook/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    location /health {
        proxy_pass http://hrm_backend/health;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}
